<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flood Risk Prediction</title>
<style>
  :root {
    --bg: #0a1120;
    --card-bg: #101a2e;
    --card-border: #1e2c47;
    --input-bg: #16223b;
    --input-border: #263a5c;
    --text-main: #e7edf7;
    --text-muted: #7c8aa5;
    --accent: #29b6f6;
    --accent-light: #4fc3f7;
    --label-blue: #38bdf8;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    padding: 40px 20px;
    background: linear-gradient(180deg, #0a1120 0%, #0b1426 100%);
    background-image:
      repeating-linear-gradient(180deg, rgba(255,255,255,0.015) 0px, rgba(255,255,255,0.015) 1px, transparent 1px, transparent 40px);
    font-family: 'Segoe UI', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    color: var(--text-main);
    min-height: 100vh;
  }

  .container {
    max-width: 1360px;
    margin: 0 auto;
  }

  /* Stats row */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 28px;
  }

  .stat-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 20px 22px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .stat-icon {
    width: 42px;
    height: 42px;
    min-width: 42px;
    border-radius: 10px;
    background: rgba(41, 182, 246, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-light);
  }

  .stat-icon svg { width: 22px; height: 22px; }

  .stat-label {
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .stat-value {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-main);
  }

  /* Form card */
  .form-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    padding: 32px 36px 36px;
  }

  .form-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 28px;
    color: var(--text-main);
  }

  .form-title svg {
    width: 20px;
    height: 20px;
    color: var(--accent-light);
  }

  .field-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px 24px;
    margin-bottom: 6px;
  }

  .field {
    display: flex;
    flex-direction: column;
  }

  .field label.field-name {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--label-blue);
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .field input {
    background: var(--input-bg);
    border: 1px solid var(--input-border);
    border-radius: 8px;
    padding: 13px 14px;
    color: var(--text-main);
    font-size: 15px;
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    width: 100%;
  }

  .field input::placeholder {
    color: #5b6b87;
  }

  .field input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(41, 182, 246, 0.15);
  }

  .field .field-hint {
    font-size: 12.5px;
    color: var(--text-muted);
    margin-top: 8px;
  }

  .actions {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .btn {
    width: 100%;
    padding: 16px 20px;
    border-radius: 10px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border: none;
    font-family: inherit;
    transition: transform 0.08s ease, filter 0.15s ease;
  }

  .btn:active { transform: scale(0.995); }

  .btn-predict {
    background: linear-gradient(90deg, #1e88e5 0%, #29b6f6 100%);
    color: #ffffff;
    box-shadow: 0 8px 24px rgba(41, 182, 246, 0.25);
  }

  .btn-predict:hover { filter: brightness(1.08); }

  .btn-reset {
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--input-border);
  }

  .btn-reset:hover {
    color: var(--text-main);
    border-color: #3a4d70;
  }

  .btn svg { width: 18px; height: 18px; }

  @media (max-width: 900px) {
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .field-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 520px) {
    .stats-row { grid-template-columns: 1fr; }
    .field-grid { grid-template-columns: 1fr; }
    .form-card { padding: 24px 20px; }
  }
</style>
</head>
<body>
  <div class="container">

    <!-- Stats row -->
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2a2.5 2.5 0 0 1 2.45 2H12a2.5 2.5 0 0 1 5 0h.05A2.5 2.5 0 0 1 19 6.45V7a2.5 2.5 0 0 1 0 5v.55A2.5 2.5 0 0 1 17 15h-.05A2.5 2.5 0 0 1 12 15h-.05A2.5 2.5 0 0 1 7 12.55V12a2.5 2.5 0 0 1 0-5v-.55A2.5 2.5 0 0 1 9.5 4z"/><path d="M12 22v-7"/></svg>
        </div>
        <div>
          <div class="stat-label">Algorithm</div>
          <div class="stat-value">XGBoost</div>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 17 9 11 13 15 21 7"/><polyline points="14 7 21 7 21 14"/></svg>
        </div>
        <div>
          <div class="stat-label">Model Accuracy</div>
          <div class="stat-value">96.55%</div>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="8" ry="3"/><path d="M4 5v6c0 1.66 3.58 3 8 3s8-1.34 8-3V5"/><path d="M4 11v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6"/></svg>
        </div>
        <div>
          <div class="stat-label">Training Records</div>
          <div class="stat-value">2,500 years</div>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div>
          <div class="stat-label">ROC-AUC</div>
          <div class="stat-value">&ge; 0.99</div>
        </div>
      </div>
    </div>

    <!-- Form card -->
    <div class="form-card">
      <div class="form-title">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>
        Enter Weather Parameters
      </div>

      <form id="flood-form">
        <div class="field-grid">
          <div class="field">
            <label class="field-name" for="annual-rainfall">Annual Rainfall (mm)</label>
            <input type="number" id="annual-rainfall" name="annual_rainfall" placeholder="e.g. 1250">
            <div class="field-hint">Total yearly rainfall</div>
          </div>

          <div class="field">
            <label class="field-name" for="jan-feb-rainfall">Jan&ndash;Feb Rainfall (mm)</label>
            <input type="number" id="jan-feb-rainfall" name="jan_feb_rainfall" placeholder="e.g. 50">
            <div class="field-hint">Winter season total</div>
          </div>

          <div class="field">
            <label class="field-name" for="mar-may-rainfall">Mar&ndash;May Rainfall (mm)</label>
            <input type="number" id="mar-may-rainfall" name="mar_may_rainfall" placeholder="e.g. 120">
            <div class="field-hint">Pre-monsoon total</div>
          </div>

          <div class="field">
            <label class="field-name" for="jun-sep-rainfall">Jun&ndash;Sep Rainfall (mm)</label>
            <input type="number" id="jun-sep-rainfall" name="jun_sep_rainfall" placeholder="e.g. 900">
            <div class="field-hint">Monsoon season total</div>
          </div>

          <div class="field">
            <label class="field-name" for="oct-dec-rainfall">Oct&ndash;Dec Rainfall (mm)</label>
            <input type="number" id="oct-dec-rainfall" name="oct_dec_rainfall" placeholder="e.g. 140">
            <div class="field-hint">Post-monsoon total</div>
          </div>

          <div class="field">
            <label class="field-name" for="year">Year</label>
            <input type="number" id="year" name="year" placeholder="e.g. 2024">
            <div class="field-hint">Observation year</div>
          </div>
        </div>

        <div class="actions">
          <button type="submit" class="btn btn-predict">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z"/></svg>
            Predict Flood Risk
          </button>
          <button type="reset" class="btn btn-reset">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
            Reset
          </button>
        </div>
      </form>
    </div>

  </div>

  <script>
    document.getElementById('flood-form').addEventListener('submit', function(e) {
      e.preventDefault();
      // Hook up prediction logic here
      alert('Predict Flood Risk clicked — wire this up to your model endpoint.');
    });
  </script>
</body>
</html>
